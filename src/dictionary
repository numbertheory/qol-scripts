#!/usr/bin/env bash

source set-colors

TARGET_WORD=$1

if [[ -z "$TARGET_WORD" ]]; then
    echo -e "${RED}Error${RESET}: No search word provided."
    echo -e "Usage: dictionary <word>"
    exit 1
fi

# 1️⃣ Grab the initial context from /usr/share/dict/words
raw_candidates=$(grep -i -C 10 "^${TARGET_WORD}$" /usr/share/dict/words | grep -v '^--$')

if [[ -z "$raw_candidates" ]]; then
    echo "Word '$TARGET_WORD' not found."
    exit 1
fi

# 2️⃣ Filter candidates to ONLY those that have a macOS Dictionary entry
# We use a compact Python loop to check each word
candidates=$(echo "$raw_candidates" | python3 -c "
import sys
from CoreServices import DCSCopyTextDefinition
for line in sys.stdin:
    word = line.strip()
    if DCSCopyTextDefinition(None, word, (0, len(word))):
        print(word)
")

# 3️⃣ Recalculate the line number based on the NEW filtered list
LINE_NUM=$(echo "$candidates" | grep -ni "^${TARGET_WORD}$" | head -n 1 | cut -d: -f1)
LINE_NUM=${LINE_NUM:-1}

# 4️⃣ Launch fzf
echo "$candidates" | fzf \
    --prompt="macOS Dictionary: " \
    --preview-window=right:70%:wrap \
    --preview='
        python3 -c "
import sys
from CoreServices import DCSCopyTextDefinition
word = sys.argv[1].strip()
result = DCSCopyTextDefinition(None, word, (0, len(word)))
print(result if result else \"No definition found.\")
        " {}' \
    --style=full \
    --layout=reverse \
    --bind "start:pos($LINE_NUM)"
