#!/usr/bin/env bash

source set-colors

# --- PRE-FLIGHT CHECKS ---

# 1. Check if running on macOS
if [[ "$OSTYPE" != "darwin"* ]]; then
    echo -e "${RED}Error${RESET}: This script requires macOS Dictionary Services."
    exit 1
fi

# 2. Check if fzf is installed
if ! command -v fzf &> /dev/null; then
    echo -e "${RED}Error${RESET}: 'fzf' is not installed. Install it with: brew install fzf"
    exit 1
fi

# 3. Check for the required Python library
# We check if 'CoreServices' can be imported in python3
if ! python3 -c "import CoreServices" &> /dev/null; then
    echo -e "${RED}Error${RESET}: Missing 'pyobjc-framework-CoreServices'."
    echo -e "Fix: pip3 install pyobjc-framework-CoreServices"
    exit 1
fi

# Initialize our mode variable as empty
THES_FLAG=""

# 1. Parse flags
# This loop looks for -t and shifts the arguments list so $1 remains the word
while [[ "$#" -gt 0 ]]; do
    case $1 in
        -t|--thesaurus)
            THES_FLAG="-t"
            shift # Remove -t from the argument list
            ;;
        *)
            break # Stop parsing at the first non-flag argument (the word)
            ;;
    esac
done

# 2. Assign positional arguments
# Now that flags are shifted out, $1 is the word and $2 is the dictionary query
TARGET_WORD=$1
DICTIONARY_QUERY=${2:-"Oxford"}

# 3. Resolve the dictionary name
# We pass $THES_FLAG here. If -t was used, it's "-t"; otherwise, it's empty.
DICTIONARY_IN_USE="$(python3 "$QOL_SCRIPTS_PATH/util/dictionary.py" $THES_FLAG -s "$DICTIONARY_QUERY")"

if [[ -z "$TARGET_WORD" ]]; then
    echo -e "${RED}Error${RESET}: No search word provided."
    echo -e "Usage: dictionary <word>"
    exit 1
fi

# 1️⃣ Grab context
raw_candidates=$(grep -i -C 100 "^${TARGET_WORD}$" /usr/share/dict/words | grep -v '^--$')

if [[ -z "$raw_candidates" ]]; then
    echo "Word '$TARGET_WORD' not found."
    exit 1
fi

# 2️⃣ Filter candidates
candidates=$(echo "$raw_candidates" | python3 -c "
import sys
from CoreServices import DCSCopyTextDefinition
for line in sys.stdin:
    word = line.strip()
    if DCSCopyTextDefinition(None, word, (0, len(word))):
        print(word)
")

# 3️⃣ Calculate Line Number
LINE_NUM=$(echo "$candidates" | grep -ni "^${TARGET_WORD}$" | head -n 1 | cut -d: -f1)
LINE_NUM=${LINE_NUM:-1}

# 4️⃣ Launch fzf with --ansi and Enhanced Python Formatting
echo "$candidates" | fzf \
    --ansi \
    --prompt="macOS Dictionary: " \
    --preview-window=right:70%:wrap \
    --preview="python3 $QOL_SCRIPTS_PATH/util/dictionary.py $THES_FLAG -d \"$DICTIONARY_IN_USE\"  {}" \
    --style=full \
    --layout=reverse \
    --bind "start:pos($LINE_NUM)" \
    --bind "enter:become(python3 $QOL_SCRIPTS_PATH/util/dictionary.py $THES_FLAG -d \"$DICTIONARY_IN_USE\" {})"
