#!/usr/bin/env bash

# Description: Show all branches of a git folder/view all commits of a branch.

# --- Configuration ---
FOLDER=$PWD

# Parse flags
while getopts "f:" opt; do
  case $opt in
    f) FOLDER="$OPTARG" ;;
    *) echo "Usage: $0 [-f folder]"; exit 1 ;;
  esac
done

# Ensure the directory exists and is a git repo
if [[ ! -d "$FOLDER/.git" ]]; then
    echo "Error: '$FOLDER' is not a git repository."
    exit 1
fi

# Function to show commits for a specific branch
show_commits() {
    local branch=$1
    # We use {1} in fzf because it's the first column (the hash)
    git -C "$FOLDER" log "$branch" \
        --color=always \
        --format="%C(auto)%h %C(reset)%s %C(magenta)%cr%C(reset)" | \
    fzf --ansi \
        --layout=reverse \
        --header "Commits for [$branch] (Enter/Esc to go back)" \
        --no-sort \
        --preview "git -C '$FOLDER' show --color=always {1}" \
        --preview-window=right:70%:wrap
}

# Main loop to keep the script "running again" until user exits
while true; do
    # 1. Get branch list
    # 2. Strip current branch indicator (*) and 'remotes/' prefix
    # 3. Filter out HEAD
    selected_branch=$(git -C "$FOLDER" branch --all \
        | sed -E 's/^[* ]+//' \
        | sed 's|remotes/||' \
        | grep -v '^origin/HEAD' \
        | sort -u \
        | fzf --ansi \
            --layout=reverse \
            --border \
            --header "Select Branch (Esc to quit)" \
            --preview-window=right:70%:wrap \
            --preview "git -C '$FOLDER' log --graph --decorate --color=always --pretty=format:'%C(bold blue)%h%C(reset) -%C(bold yellow)%d%C(reset) %C(green)%cr%C(reset) %C(bold)%s%C(reset)' {}")

    # If user presses Esc or provides no input, exit the script
    [[ -z "$selected_branch" ]] && break

    # Enter the commit view for the selected branch
    show_commits "$selected_branch"
done
