#!/usr/bin/env bash
# Emoji picker using fzf
# Description: Search for emojis and copy them to your clipboard
#

# Define a cleanup function
cleanup() {
    # Clear the scrollвҖ‘back buffer (optional)
    printf '\e[3J'   # same as CtrlвҖ‘ShiftвҖ‘K in Kitty
    # Remove all Kitty graphics that were drawn
    kitty +kitten icat --clear
}
# Register the function to run on exit (normal or error)
trap cleanup EXIT


# ----------------------------------------------------------------------
# 1. Emoji list
# ----------------------------------------------------------------------
# Each line: <emoji><tab><description>
EMOJI_DATA=$(cat $QOL_SCRIPTS_PATH/src/emoji-list.txt)

# Determine the tone to use. Command line argument takes precedence over environment variable.
if [[ -n "$1" && "$1" == --* ]]; then
    INPUT_TONE="${1#--}"
else
    INPUT_TONE="${QOL_EMOJI_SKIN_TONE}"
fi
MULTI_TONE=false
SHOW_ALL_TONES=${QOL_SHOW_ALL_TONES:-false}
case "$INPUT_TONE" in
    cache)
        TONE1=$'\U1F3FB'
        TONE2=$'\U1F3FC'
        TONE3=$'\U1F3FD'
        TONE4=$'\U1F3FE'
        TONE5=$'\U1F3FF'
        TONES=("" "$TONE1" "$TONE2" "$TONE3" "$TONE4" "$TONE5")
        EMOJI_COUNTER=0
        RENDER_FONT=${2:-"Noto-Color-Emoji"}
        echo "Caching emoji images for the system."
        echo "Using $RENDER_FONT for the font."
        echo "$EMOJI_DATA" | while IFS=$'\t' read -r emoji desc; do
            case "$emoji" in
                # PROFESSIONAL: Inject Tone before the Joiner (e.g., рҹ‘Ё + TONE + ZWJ + рҹҺЁ)
                # When adding to this list, use the  form to cover all three forms.
                "рҹ‘Ё"*|"рҹ‘©"*|"рҹ§‘"*|"рҹҡЈ"*|"рҹҸғ"*|"рҹҡ¶"*|"рҹҸҠ"*| \
                "рҹҸӢ"*|"рҹ§—"*|"рҹ§–"*|"рҹҡҙ"*|"рҹҡө"*|"рҹ§ҳ"*|"вӣ№пёҸ"*| \
                "рҹҸҢпёҸ"*|"рҹҸ„"*|"рҹӨә"*|"рҹӨ№"*|"рҹ•ҙпёҸ"*|"рҹӨҪ"*|"рҹӨҫ"*| \
                "рҹ‘Ҝ"*|"вӣ·пёҸ"*|"рҹ’ғ"*|"рҹ•ә"*|"рҹ§Ҹ"*|"рҹ‘і"*|"рҹҷҺ"*| \
                "рҹҷҚ"*|"рҹҷ…"*|"рҹҷҶ"*|"рҹ’Ғ"*|"рҹҷӢ"*|"рҹҷҮ"*|"рҹӨҰ"*| \
                "рҹӨ·"*|"рҹ§‘вҖҚрҹ©°"*|"рҹӨё"*|"рҹ’Ҷ"*|"рҹӣҖ"*|"рҹ§ң"*|"рҹ§қ"*| \
                "рҹ§ҷ"*|"рҹ§ӣ"*|"рҹҰё"*|"рҹҰ№"*|"рҹ§‘вҖҚвҡ•пёҸ"*|"рҹ§‘вҖҚрҹҸ«"*|"рҹ§‘вҖҚвҡ–пёҸ"*| \
                "рҹ§‘вҖҚрҹҢҫ"*|"рҹ§‘вҖҚрҹ”§"*|"рҹ§‘вҖҚрҹҸӯ"*|"рҹ§‘вҖҚрҹ”¬"*|"рҹ§‘вҖҚрҹ’»"*|"рҹ§‘вҖҚрҹҺӨ"*|"рҹ§‘вҖҚрҹҺЁ"*| \
                "рҹ§‘вҖҚвңҲпёҸ"*|"рҹ§‘вҖҚрҹҡҖ"*|"рҹ§‘вҖҚрҹҡ’"*|"рҹ‘®"*|"рҹ•өпёҸ"*|"рҹ’Ӯ"*|"рҹ‘·"*| \
                "рҹӨҙ"*|"рҹ‘ё"*|"рҹ‘і"*|"рҹӨө"*|"рҹ‘°"*|"рҹ§‘вҖҚрҹҡҖ"*)
                for tone in "${TONES[@]}"; do
                        ((EMOJI_COUNTER++))
                        # Combine base emoji with the tone modifier
                        BASE_CHAR="${emoji:0:1}"
                        REST_CHAR="${emoji:1}"
                        CURRENT_EMOJI="${BASE_CHAR}${tone}${REST_CHAR}"

                        # Update UI
                        echo -ne "\r\033[KProcessing: $CURRENT_EMOJI ($EMOJI_COUNTER) | $desc"

                        # Call your existing emoji-printer script
                        emoji-printer "$CURRENT_EMOJI" $RENDER_FONT
                done;
                ;;
                "рҹ––"|"рҹӨҳ"|"рҹӨҹ"|"рҹӨһ"|"вңӢ"|"вңҠ"|"рҹ‘Ҹ"|"рҹӨҡ"| \
                "вңӢпёҸ"|"рҹҷҢ"|"рҹӨҷ"|"рҹ‘җ"|"рҹӨқ"|"рҹ‘Қ"|"рҹ‘Һ"|"рҹ‘Ҡ"| \
                "рҹ‘Ң"|"рҹ‘Ӣ"|"рҹ’Ә"|"рҹӨі"|"рҹ‘Ӯ"|"рҹ‘ғ"|"рҹӨІ"|"рҹ–җ"| \
                "вңҢпёҸ"|"рҹӨҸ"|"рҹӨҢ"|"рҹ‘Ң"|"рҹ«ё"|"рҹ«·"|"рҹ«ҙ"|"рҹ«і"| \
                "рҹ«І"|"рҹ«ұ"|"рҹ«ө"|"рҹ‘Ҡ"|"рҹӨӣ"|"рҹӨң"|"рҹ«¶"|"рҹ«°"| \
                "рҹ‘Ҳ"|"рҹ‘ү"|"рҹ‘Ҷ"|"вҳқпёҸ"|"рҹ‘Ү"|"рҹ–•"|"рҹҷҸ"|"вңҚпёҸ"| \
                "рҹ’…"|"рҹҰө"|"рҹҰ¶"|"рҹҰ»"|"рҹ‘¶"|"рҹ§’"|"рҹ‘Ұ"|"рҹ‘§"| \
                "рҹ§‘"|"рҹ‘ұ"|"рҹ‘Ё"|"рҹ§”"|"рҹ§”вҖҚвҷӮпёҸ"|"рҹ§”вҖҚвҷҖпёҸ"|"рҹ‘ЁвҖҚрҹҰ°"|"рҹ‘ЁвҖҚрҹҰұ"| \
                "рҹ‘ЁвҖҚрҹҰі"|"рҹ‘ЁвҖҚрҹҰІ"|"рҹ‘©"|"рҹ‘©вҖҚрҹҰ°"|"рҹ§‘вҖҚрҹҰ°"|"рҹ‘©вҖҚрҹҰұ"|"рҹ§‘вҖҚрҹҰұ"|"рҹ‘©вҖҚрҹҰі"| \
                "рҹ§‘вҖҚрҹҰі"|"рҹ‘©вҖҚрҹҰІ"|"рҹ§‘вҖҚрҹҰІ"|"рҹ‘ұвҖҚвҷҖпёҸ"|"рҹ‘ұвҖҚвҷӮпёҸ"|"рҹ§“"|"рҹ‘ҙ"|"рҹ‘ө"| \
                "рҹ‘І"|"рҹ§•"|"рҹӨ°"|"рҹ«ғ"|"рҹ«„"|"рҹ‘ј")
                for tone in "${TONES[@]}"; do
                    ((EMOJI_COUNTER++))
                    CURRENT_EMOJI="${emoji}${tone}"

                    # Update UI
                    echo -ne "\r\033[KProcessing: $CURRENT_EMOJI ($EMOJI_COUNTER) | $desc"

                    # Call your existing emoji-printer script
                    emoji-printer "$CURRENT_EMOJI" $RENDER_FONT
                done;
                ;;
                *)
                    ((EMOJI_COUNTER++))
                    echo -ne "\r\033[KProcessing: $emoji ($EMOJI_COUNTER) | $desc"
                    emoji-printer "$emoji" $RENDER_FONT
                ;;
            esac
        done
        echo -e "\nProcessing complete! Images generated and cached in ${QOL_SCRIPTS_PATH}/cache/emoji/"
        exit 0
        ;;
    light)
        TONE1=$'\U1F3FB'
        TONE2=$'\U1F3FC'
        TONE3=$'\U1F3FD'
        TONE4=$'\U1F3FE'
        TONE5=$'\U1F3FF'
        MULTI_TONE=true
        ;;
    medium-light)
        TONE1=$'\U1F3FC'
        TONE2=$'\U1F3FD'
        TONE3=$'\U1F3FE'
        TONE4=$'\U1F3FF'
        TONE5=$'\U1F3FB'
        MULTI_TONE=true
        ;;
    medium)
        TONE1=$'\U1F3FD'
        TONE2=$'\U1F3FE'
        TONE3=$'\U1F3FF'
        TONE4=$'\U1F3FB'
        TONE5=$'\U1F3FC'
        MULTI_TONE=true
        ;;
    medium-dark)
        TONE1=$'\U1F3FE'
        TONE2=$'\U1F3FF'
        TONE3=$'\U1F3FB'
        TONE4=$'\U1F3FC'
        TONE5=$'\U1F3FD'
        MULTI_TONE=true
        ;;
    dark)
        TONE1=$'\U1F3FF'
        TONE2=$'\U1F3FB'
        TONE3=$'\U1F3FC'
        TONE4=$'\U1F3FD'
        TONE5=$'\U1F3FE'
        MULTI_TONE=true
        ;;
    *)
        TONE1=""
        MULTI_TONE=false
        ;;
esac



# ----------------------------------------------------------------------
# 3. Process Emojis (Inject Tones)
# ----------------------------------------------------------------------
PROCESSED_DATA=$(echo "$EMOJI_DATA" | while IFS=$'\t' read -r emoji desc; do
    case "$emoji" in
        # PROFESSIONAL: Inject Tone before the Joiner (e.g., рҹ‘Ё + TONE + ZWJ + рҹҺЁ)
        # When adding to this list, use the  form to cover all three forms.
        "рҹ‘Ё"*|"рҹ‘©"*|"рҹ§‘"*|"рҹҡЈ"*|"рҹҸғ"*|"рҹҡ¶"*|"рҹҸҠ"*| \
        "рҹҸӢ"*|"рҹ§—"*|"рҹ§–"*|"рҹҡҙ"*|"рҹҡө"*|"рҹ§ҳ"*|"вӣ№пёҸ"*| \
        "рҹҸҢпёҸ"*|"рҹҸ„"*|"рҹӨә"*|"рҹӨ№"*|"рҹ•ҙпёҸ"*|"рҹӨҪ"*|"рҹӨҫ"*| \
        "рҹ‘Ҝ"*|"вӣ·пёҸ"*|"рҹ’ғ"*|"рҹ•ә"*|"рҹ§Ҹ"*|"рҹ‘і"*|"рҹҷҺ"*| \
        "рҹҷҚ"*|"рҹҷ…"*|"рҹҷҶ"*|"рҹ’Ғ"*|"рҹҷӢ"*|"рҹҷҮ"*|"рҹӨҰ"*| \
        "рҹӨ·"*|"рҹ§‘вҖҚрҹ©°"*|"рҹӨё"*|"рҹ’Ҷ"*|"рҹӣҖ"*|"рҹ§ң"*|"рҹ§қ"*| \
        "рҹ§ҷ"*|"рҹ§ӣ"*|"рҹҰё"*|"рҹҰ№"*|"рҹ§‘вҖҚвҡ•пёҸ"*|"рҹ§‘вҖҚрҹҸ«"*|"рҹ§‘вҖҚвҡ–пёҸ"*| \
        "рҹ§‘вҖҚрҹҢҫ"*|"рҹ§‘вҖҚрҹ”§"*|"рҹ§‘вҖҚрҹҸӯ"*|"рҹ§‘вҖҚрҹ”¬"*|"рҹ§‘вҖҚрҹ’»"*|"рҹ§‘вҖҚрҹҺӨ"*|"рҹ§‘вҖҚрҹҺЁ"*| \
        "рҹ§‘вҖҚвңҲпёҸ"*|"рҹ§‘вҖҚрҹҡҖ"*|"рҹ§‘вҖҚрҹҡ’"*|"рҹ‘®"*|"рҹ•өпёҸ"*|"рҹ’Ӯ"*|"рҹ‘·"*| \
        "рҹӨҙ"*|"рҹ‘ё"*|"рҹ‘і"*|"рҹӨө"*|"рҹ‘°"*|"рҹ§‘вҖҚрҹҡҖ"*)

            BASE_CHAR="${emoji:0:1}"
            REST_CHAR="${emoji:1}"
            if [ "$MULTI_TONE" = true ] && [ "$SHOW_ALL_TONES" = true ]; then
            printf "%s%b%s\t%s\n%s%b%s\t%s\n%s%b%s\t%s\n%s%b%s\t%s\n%s%b%s\t%s\n%s%b%s\t%s\n" \
                "$BASE_CHAR" "$TONE1" "$REST_CHAR" "$desc" \
                "$BASE_CHAR" "$TONE2" "$REST_CHAR" "$desc" \
                "$BASE_CHAR" "$TONE3" "$REST_CHAR" "$desc" \
                "$BASE_CHAR" "$TONE4" "$REST_CHAR" "$desc" \
                "$BASE_CHAR" "$TONE5" "$REST_CHAR" "$desc" \
                "$BASE_CHAR" "" "$REST_CHAR" "$desc"
            else
            printf "%s%b%s\t%s\n" "$BASE_CHAR" "$TONE1" "$REST_CHAR" "$desc"
            fi
            ;;
        # STANDARD HUMAN: Simple suffixing
        "рҹ––"|"рҹӨҳ"|"рҹӨҹ"|"рҹӨһ"|"вңӢ"|"вңҠ"|"рҹ‘Ҹ"|"рҹӨҡ"| \
        "вңӢпёҸ"|"рҹҷҢ"|"рҹӨҷ"|"рҹ‘җ"|"рҹӨқ"|"рҹ‘Қ"|"рҹ‘Һ"|"рҹ‘Ҡ"| \
        "рҹ‘Ң"|"рҹ‘Ӣ"|"рҹ’Ә"|"рҹӨі"|"рҹ‘Ӯ"|"рҹ‘ғ"|"рҹӨІ"|"рҹ–җ"| \
        "вңҢпёҸ"|"рҹӨҸ"|"рҹӨҢ"|"рҹ‘Ң"|"рҹ«ё"|"рҹ«·"|"рҹ«ҙ"|"рҹ«і"| \
        "рҹ«І"|"рҹ«ұ"|"рҹ«ө"|"рҹ‘Ҡ"|"рҹӨӣ"|"рҹӨң"|"рҹ«¶"|"рҹ«°"| \
        "рҹ‘Ҳ"|"рҹ‘ү"|"рҹ‘Ҷ"|"вҳқпёҸ"|"рҹ‘Ү"|"рҹ–•"|"рҹҷҸ"|"вңҚпёҸ"| \
        "рҹ’…"|"рҹҰө"|"рҹҰ¶"|"рҹҰ»"|"рҹ‘¶"|"рҹ§’"|"рҹ‘Ұ"|"рҹ‘§"| \
        "рҹ§‘"|"рҹ‘ұ"|"рҹ‘Ё"|"рҹ§”"|"рҹ§”вҖҚвҷӮпёҸ"|"рҹ§”вҖҚвҷҖпёҸ"|"рҹ‘ЁвҖҚрҹҰ°"|"рҹ‘ЁвҖҚрҹҰұ"| \
        "рҹ‘ЁвҖҚрҹҰі"|"рҹ‘ЁвҖҚрҹҰІ"|"рҹ‘©"|"рҹ‘©вҖҚрҹҰ°"|"рҹ§‘вҖҚрҹҰ°"|"рҹ‘©вҖҚрҹҰұ"|"рҹ§‘вҖҚрҹҰұ"|"рҹ‘©вҖҚрҹҰі"| \
        "рҹ§‘вҖҚрҹҰі"|"рҹ‘©вҖҚрҹҰІ"|"рҹ§‘вҖҚрҹҰІ"|"рҹ‘ұвҖҚвҷҖпёҸ"|"рҹ‘ұвҖҚвҷӮпёҸ"|"рҹ§“"|"рҹ‘ҙ"|"рҹ‘ө"| \
        "рҹ‘І"|"рҹ§•"|"рҹӨ°"|"рҹ«ғ"|"рҹ«„"|"рҹ‘ј")
            if [ "$MULTI_TONE" = true ] && [ "$SHOW_ALL_TONES" = true ]; then
            printf "%s%b\t%s\n%s%b\t%s\n%s%b\t%s\n%s%b\t%s\n%s%b\t%s\n%s%b\t%s\n" \
                "$emoji" "$TONE1" "$desc" \
                "$emoji" "$TONE2" "$desc" \
                "$emoji" "$TONE3" "$desc" \
                "$emoji" "$TONE4" "$desc" \
                "$emoji" "$TONE5" "$desc" \
                "$emoji" "" "$desc" \

            else
            printf "%s%b\t%s\n" "$emoji" "$TONE1" "$desc"
            fi
            ;;
        # DEFAULT: All non-human/non-tonable emojis
        *)
            printf "%s\t%s\n" "$emoji" "$desc"
            ;;
    esac
done)

# ----------------------------------------------------------------------
# 4. Run fzf with Swatch Indicator
# ----------------------------------------------------------------------
PROMPT_STR=$(printf "Pick an emoji%b> ")

SELECTED=$(echo "$PROCESSED_DATA" |
    fzf --ansi \
        --prompt="$PROMPT_STR" \
        --border=none \
        --height=40% \
        --preview '
            emoji=$(echo -n {1})
            unicode_hex=$(echo -n "$emoji" | iconv -f UTF-8 -t UTF-32BE | hexdump -ve "1/4 \"%08x\" \" \" ")
            clean_hex=$(echo $unicode_hex | sed "s/ /_/g; s/_$//")

            # Calculate half-scale dimensions
            cols=$((FZF_PREVIEW_COLUMNS / 2))
            rows=$((FZF_PREVIEW_LINES / 2))

            echo $clean_hex | sed "s/\"//g" | xargs -I FILE kitty icat --clear --transfer-mode=memory --stdin=no \
            --place="${cols}x${rows}@0x0" "$QOL_SCRIPTS_PATH/cache/emoji/emoji_FILE.png"'\
        --preview-window=noborder:right:70%:wrap \
        --layout=reverse \
        --delimiter=$'\t' \
        --nth=2 \
        --ignore-case \
        --exact)

# ----------------------------------------------------------------------
# 5. Output and Clipboard
# ----------------------------------------------------------------------
if [[ -n $SELECTED ]]; then
    EMOJI=$(cut -f1 <<<"$SELECTED")

    if command -v pbcopy >/dev/null 2>&1; then
        printf "%s" "$EMOJI" | pbcopy
    elif command -v xclip >/dev/null 2>&1; then
        printf "%s" "$EMOJI" | xclip -selection clipboard
    fi

fi

# ----------------------------------------------------------------------
# 3. Output the chosen emoji
# ----------------------------------------------------------------------
if [[ -n $SELECTED ]]; then
    EMOJI=$(cut -f1 <<<"$SELECTED")

    # Clipboard handling (Linux/macOS)
    if command -v xclip >/dev/null 2>&1; then
        printf "%s" "$EMOJI" | xclip -selection clipboard
    elif command -v xsel >/dev/null 2>&1; then
        printf "%s" "$EMOJI" | xsel --clipboard --input
    elif command -v pbcopy >/dev/null 2>&1; then
        printf "%s" "$EMOJI" | pbcopy
    fi

    printf "%s\n" "$EMOJI"
fi
