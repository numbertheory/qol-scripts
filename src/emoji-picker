#!/usr/bin/env bash
# Emoji picker using fzf
# Description: Search for emojis and copy them to your clipboard

BASE=$'\U25EF' # Large Circle

case "$1" in
    --light)
        TONE=$'\U1F3FB'
        INDICATOR=" (${BASE}${TONE}) "
        ;;
    --medium-light)
        TONE=$'\U1F3FC'
        INDICATOR=" (${BASE}${TONE}) "
        ;;
    --medium)
        TONE=$'\U1F3FD'
        INDICATOR=" (${BASE}${TONE}) "
        ;;
    --medium-dark)
        TONE=$'\U1F3FE'
        INDICATOR=" (${BASE}${TONE}) "
        ;;
    --dark)
        TONE=$'\U1F3FF'
        INDICATOR=" (${BASE}${TONE}) "
        ;;
    *)
        TONE=""
        INDICATOR=""
        ;;
esac

