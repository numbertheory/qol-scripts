# ----------------------------------------------------------------------
# 3. Process Emojis (Inject Tones)
# ----------------------------------------------------------------------
PROCESSED_DATA=$(echo "$EMOJI_DATA" | while IFS=$'\t' read -r emoji desc; do
    case "$emoji" in
        # PROFESSIONAL: Inject Tone before the Joiner (e.g., 👨 + TONE + ZWJ + 🎨)
        "👨"*|"👩"*|"🧑"*|"🚣"*|"🏃"*|"🚶"*|"🏊"*|"🏋"*|"🚴"*)
            BASE_CHAR="${emoji:0:1}"
            REST_CHAR="${emoji:1}"
            printf "%s%b%s\t%s\n" "$BASE_CHAR" "$TONE" "$REST_CHAR" "$desc"
            ;;
        # STANDARD HUMAN: Simple suffixing
        "✊"|"👏"|"🤚"|"✋️"|"🙌"|"🤙"|"👐"|"🤝"|"👍"|"👎"|"👊"|"👌"|"👋"|"💪"|"🤳"|"👂"|"👃")
             # Note: athletes also match the "Professional" logic if they start with 👨/👩
             # but simple athletes like 🏃 start here.
            printf "%s%b\t%s\n" "$emoji" "$TONE" "$desc"
            ;;
        # DEFAULT: All non-human/non-tonable emojis
        *)
            printf "%s\t%s\n" "$emoji" "$desc"
            ;;
    esac
done)

# ----------------------------------------------------------------------
# 4. Run fzf with Swatch Indicator
# ----------------------------------------------------------------------
PROMPT_STR=$(printf "Pick an emoji%b> ")

SELECTED=$(echo "$PROCESSED_DATA" |
    fzf --ansi \
        --prompt="$PROMPT_STR" \
        --height=40% \
        --layout=reverse \
        --delimiter=$'\t' \
        --nth=2 \
        --ignore-case \
        --exact)

# ----------------------------------------------------------------------
# 5. Output and Clipboard
# ----------------------------------------------------------------------
if [[ -n $SELECTED ]]; then
    EMOJI=$(cut -f1 <<<"$SELECTED")

    if command -v pbcopy >/dev/null 2>&1; then
        printf "%s" "$EMOJI" | pbcopy
    elif command -v xclip >/dev/null 2>&1; then
        printf "%s" "$EMOJI" | xclip -selection clipboard
    fi

fi

# ----------------------------------------------------------------------
# 3. Output the chosen emoji
# ----------------------------------------------------------------------
if [[ -n $SELECTED ]]; then
    EMOJI=$(cut -f1 <<<"$SELECTED")

    # Clipboard handling (Linux/macOS)
    if command -v xclip >/dev/null 2>&1; then
        printf "%s" "$EMOJI" | xclip -selection clipboard
    elif command -v xsel >/dev/null 2>&1; then
        printf "%s" "$EMOJI" | xsel --clipboard --input
    elif command -v pbcopy >/dev/null 2>&1; then
        printf "%s" "$EMOJI" | pbcopy
    fi

    printf "%s\n" "$EMOJI"
fi
