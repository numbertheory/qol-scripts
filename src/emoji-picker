        "🤴"*|"👸"*|"👳"*|"🤵"*|"👰"*|"🧑‍🚀"*)

            BASE_CHAR="${emoji:0:1}"
            REST_CHAR="${emoji:1}"
            if [ "$MULTI_TONE" = true ] && [ "$SHOW_ALL_TONES" = true ]; then
            printf "%s%b%s\t%s\n%s%b%s\t%s\n%s%b%s\t%s\n%s%b%s\t%s\n%s%b%s\t%s\n%s%b%s\t%s\n" \
