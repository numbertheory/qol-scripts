                "$BASE_CHAR" "$TONE5" "$REST_CHAR" "$desc" \
                "$BASE_CHAR" "" "$REST_CHAR" "$desc"
            else
            printf "%s%b%s\t%s\n" "$BASE_CHAR" "$TONE1" "$REST_CHAR" "$desc"
