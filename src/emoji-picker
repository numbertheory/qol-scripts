#!/usr/bin/env bash
# Emoji picker using fzf
# Description: Search for emojis and copy them to your clipboard

# Determine the tone to use. Command line argument takes precedence over environment variable.
if [[ -n "$1" && "$1" == --* ]]; then
    INPUT_TONE="${1#--}"
else
    INPUT_TONE="${QOL_EMOJI_SKIN_TONE}"
fi
MULTI_TONE=false
SHOW_ALL_TONES=${QOL_SHOW_ALL_TONES:-false}
case "$INPUT_TONE" in
    light)
        TONE1=$'\U1F3FB'
        TONE2=$'\U1F3FC'
        TONE3=$'\U1F3FD'
        TONE4=$'\U1F3FE'
        TONE5=$'\U1F3FF'
        MULTI_TONE=true
        ;;
    medium-light)
        TONE1=$'\U1F3FC'
        TONE2=$'\U1F3FD'
        TONE3=$'\U1F3FE'
        TONE4=$'\U1F3FF'
        TONE5=$'\U1F3FB'
        MULTI_TONE=true
        ;;
    medium)
        TONE1=$'\U1F3FD'
        TONE2=$'\U1F3FE'
        TONE3=$'\U1F3FF'
        TONE4=$'\U1F3FB'
        TONE5=$'\U1F3FC'
        MULTI_TONE=true
        ;;
    medium-dark)
        TONE1=$'\U1F3FE'
        TONE2=$'\U1F3FF'
        TONE3=$'\U1F3FB'
        TONE4=$'\U1F3FC'
        TONE5=$'\U1F3FD'
        MULTI_TONE=true
        ;;
    dark)
        TONE1=$'\U1F3FF'
        TONE2=$'\U1F3FB'
        TONE3=$'\U1F3FC'
        TONE4=$'\U1F3FD'
        TONE5=$'\U1F3FE'
        MULTI_TONE=true
        ;;
    *)
        TONE1=""
        MULTI_TONE=false
        ;;
esac

