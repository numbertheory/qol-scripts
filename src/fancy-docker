#!/usr/bin/env bash

# Description: Docker inspect all the local images on your system

# Check for syntax highlighting tools and set the preview command accordingly
if command -v bat >/dev/null 2>&1; then
    PREVIEW_CMD="docker inspect {1} | bat --color=always -l json"
elif command -v jq >/dev/null 2>&1; then
    PREVIEW_CMD="docker inspect {1} | jq -C ."
else
    PREVIEW_CMD="docker inspect {1}"
fi

# 1. Capture the selection into a variable
# 2. Extract the first field (the Image ID)
# 3. Run docker inspect on that ID
selected=$(docker images --format "{{.ID}}\t{{.Repository}}:{{.Tag}}\t{{.Size}}" \
    | column -t -s $'\t' \
    | fzf --header-lines=0 --preview-window=right:65%:wrap --preview "$PREVIEW_CMD")

# If a selection was made (user didn't press ESC)
if [ -n "$selected" ]; then
    # Extract the first column (the ID) and output the raw JSON
    image_id=$(echo "$selected" | awk '{print $1}')
    docker inspect "$image_id"
fi
