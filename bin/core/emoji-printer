#!/bin/bash

# Check if an argument was provided
if [ -z "$1" ]; then
    echo "Usage: $0 <emoji>"
    exit 1
fi

EMOJI=$1
OUTPUT_FILE="emoji_out.png"

# Use ImageMagick to create the image
# -size: Sets the canvas
# -background: none for transparency
# -gravity: centers the emoji
# -font: ensures the system uses an emoji-compatible font
# pango: a rendering engine that handles color emojis better than standard label:
magick -size 640x640 \
       -background none \
       -gravity center \
       -font "Noto-Color-Emoji" \
       pango:"<span size='400000'>$EMOJI</span>" \
       "$OUTPUT_FILE"

echo "Success! Created $OUTPUT_FILE"
