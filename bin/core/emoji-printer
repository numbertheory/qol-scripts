#!/bin/bash

# Check if an argument was provided
if [ -z "$1" ]; then
    echo "Usage: $0 <emoji>"
    exit 1
fi

EMOJI=$1

# 1. Convert the emoji to its hex representation
# This handles skin tones (modifiers) and multi-part emojis (ZWJ sequences)
UNICODE_HEX=$(echo -n "$EMOJI" | iconv -f UTF-8 -t UTF-32BE | hexdump -ve '1/4 "%08x" " "')
# Trim whitespace and format for filename
CLEAN_HEX=$(echo $UNICODE_HEX | sed 's/ /_/g')

OUTPUT_FILE="emoji_${CLEAN_HEX}.png"

# 2. Use ImageMagick with Pango for high-quality rendering
magick -size 640x640 \
       -background none \
       -gravity center \
       -font "Noto-Color-Emoji" \
       pango:"<span size='400000'>$EMOJI</span>" \
       "$OUTPUT_FILE"

echo "Success! Created: $OUTPUT_FILE"
