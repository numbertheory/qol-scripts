#!/bin/bash

# Check if an argument was provided
if [ -z "$1" ]; then
    echo "Usage: $0 <emoji>"
    exit 1
fi

EMOJI=$1
FONT=$2

# 1. Convert the emoji to its hex representation
# This handles skin tones (modifiers) and multi-part emojis (ZWJ sequences)
UNICODE_HEX=$(echo -n "$EMOJI" | iconv -f UTF-8 -t UTF-32BE | hexdump -ve '1/4 "%08x" " "')
# Trim whitespace and format for filename
CLEAN_HEX=$(echo $UNICODE_HEX | sed 's/ /_/g')
mkdir -p "${QOL_SCRIPTS_PATH}/cache/emoji"
OUTPUT_FILE="${QOL_SCRIPTS_PATH}/cache/emoji/emoji_${CLEAN_HEX}.png"

# 2. Use ImageMagick with Pango for high-quality rendering
if [[ "$(uname -s)" == "Darwin" ]]; then
    # Your new macOS Swift-based printer
    if [[ ! -f "$OUTPUT_FILE" ]]; then
        apple-emoji-printer "$EMOJI" "$OUTPUT_FILE" 640
    fi
else
    if [[ ! -f "$OUTPUT_FILE" ]]; then
        # Linux logic
        # Fallback to a common Linux emoji font if $FONT isn't set
        FONT_TO_USE="${FONT:-Noto-Color-Emoji}"

        magick -size 640x640 \
            -background none \
            -gravity center \
            -font "$FONT_TO_USE" \
            pango:"<span size='400000'>$EMOJI</span>" \
            "$OUTPUT_FILE"
    fi
fi
