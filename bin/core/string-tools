#!/usr/bin/env bash

# Description: Common string tools for Quality of Life scripts.

source set-colors

section_header() {
    echo -e "\n${BOLD}${CYAN}в†’${RESET} ${BOLD}$1${RESET}"
}

# Helper function for key-value pairs
print_kv() {
    echo -e $3 "${BLUE}$(printf '%-20.20s' "$1")${RESET} ${WHITE}${2}${RESET}"
}

text_file_stats() {
    WC_OUTPUT=$(wc -l -w -c "$FILENAME")
    TEXT_FILE_LINES=$(echo "$WC_OUTPUT" | awk '{print $1}')
    TEXT_FILE_WORDS=$(echo "$WC_OUTPUT" | awk '{print $2}')
    TEXT_FILE_CHARS=$(echo "$WC_OUTPUT" | awk '{print $3}')
    TEXT_FILE_ENCODING=$(file -b --mime-encoding "$FILENAME" 2>/dev/null)
    print_kv "Lines" "$TEXT_FILE_LINES"
    print_kv "Words" "$TEXT_FILE_WORDS"
    print_kv "Characters" "$TEXT_FILE_CHARS"
    print_kv "Encoding" "$TEXT_FILE_ENCODING"
}

# Helper function to format the 'rwx' triplets
parse_bit() {
    [[ $1 == "$2" ]] && echo "  в—Џ  " || echo "  в—‹  "
}

permissions_calc() {
    PERMS=$(ls -ld "$1" | awk '{print $1}')
    # Get the numeric version (OS-agnostic check)
    if [[ $(uname -s) == "Darwin" ]]; then
        NUMERIC_PERMS=$(stat -f "%Lp" "$1")
    else
        NUMERIC_PERMS=$(stat -c "%a" "$1")
    fi

    # Extract triplets
    U_R=$(parse_bit "${PERMS:1:1}" "r")
    U_W=$(parse_bit "${PERMS:2:1}" "w")
    U_X=$(parse_bit "${PERMS:3:1}" "x")

    G_R=$(parse_bit "${PERMS:4:1}" "r")
    G_W=$(parse_bit "${PERMS:5:1}" "w")
    G_X=$(parse_bit "${PERMS:6:1}" "x")

    O_R=$(parse_bit "${PERMS:7:1}" "r")
    O_W=$(parse_bit "${PERMS:8:1}" "w")
    O_X=$(parse_bit "${PERMS:9:1}" "x")

    print_kv "Permissions ($NUMERIC_PERMS)" "" "-n"
    # Get the numeric version (OS-agnostic check)
    if [[ $(uname -s) == "Darwin" ]]; then
        EXTRA_SPACE=""
    else
        EXTRA_SPACE="  "
    fi
    echo -e "${EXTRA_SPACE}в”Џв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”ів”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”ів”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”ів”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”“"
    echo -e "\t\t  ${EXTRA_SPACE}   в”ѓ Entity в”ѓ Read  в”ѓ Write в”ѓ Execute в”ѓ"
    echo -e "\t\t  ${EXTRA_SPACE}   в”Јв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв•‹в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв•‹в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв•‹в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”«"
    printf "\t\t   %s  в”ѓ Owner  в”ѓ%s  в”ѓ%s  в”ѓ%s    в”ѓ\n" "$EXTRA_SPACE" "$U_R" "$U_W" "$U_X"
    echo -e "\t\t  ${EXTRA_SPACE}   в”Јв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв•‹в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв•‹в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв•‹в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”«"
    printf "\t\t   %s  в”ѓ Group  в”ѓ%s  в”ѓ%s  в”ѓ%s    в”ѓ\n" "$EXTRA_SPACE" "$G_R" "$G_W" "$G_X"
    echo -e "\t\t  ${EXTRA_SPACE}   в”Јв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв•‹в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв•‹в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв•‹в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”«"
    printf "\t\t   %s  в”ѓ Others в”ѓ%s  в”ѓ%s  в”ѓ%s    в”ѓ\n" "$EXTRA_SPACE" "$O_R" "$O_W" "$O_X"
    echo -e "\t\t  ${EXTRA_SPACE}   в”—в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”»в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”»в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”»в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”›"
}
