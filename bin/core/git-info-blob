#!/usr/bin/env bash

source string-tools

FOLDER_OR_FILE="${1-"folder"}"

if [[ "$FOLDER_OR_FILE" == "file" ]]; then
    GIT_COMMIT_COUNT=$(git -C "$FOLDER" rev-list --count HEAD "$ABS_PATH" )
    GIT_CURRENT_BRANCH=$(git -C "$FOLDER" rev-parse --abbrev-ref HEAD)
    GIT_COMMIT_MSG=$(git log -n 1 --pretty=format:%s -- "$ABS_PATH")
    GIT_SHORT_COMMIT=$(git log -n 1 --pretty=format:%h -- "$ABS_PATH")
    GIT_REMOTE_URL=$(git -C "$FOLDER" remote get-url origin)
    GIT_STATUS=$(git status --porcelain "$ABS_PATH" | wc -l | awk '{if ($1==0) print "clean"; else print "dirty"}')
    GIT_LAST_COMMIT_TS=$(git --no-pager log -1 --format="%cd" --date=format:"%Y-%m-%d %H:%M:%S" "$ABS_PATH")
else
    GIT_COMMIT_COUNT=$(git -C "$FOLDER" rev-list --count HEAD)
    GIT_CURRENT_BRANCH=$(git -C "$FOLDER" rev-parse --abbrev-ref HEAD)
    GIT_COMMIT_MSG=$(git log -n 1 --pretty=format:%s HEAD)
    GIT_SHORT_COMMIT=$(git -C "$FOLDER" rev-parse --short HEAD)
    GIT_REMOTE_URL=$(git -C "$FOLDER" remote get-url origin)
    GIT_STATUS=$(git -C "$FOLDER" status --porcelain | wc -l | awk '{if ($1==0) print "clean"; else print "dirty"}')
    GIT_LAST_COMMIT_TS=$(git -C "$FOLDER" --no-pager log -1 --format="%cd" --date=format:"%Y-%m-%d %H:%M:%S")
    GIT_LATEST_TAG=$(git -C "$FOLDER" --no-pager describe --tags HEAD 2>/dev/null || echo "${GRAY}no tags set${RESET}")
fi

section_header "Git"

# Status indicator with color
if [[ "$GIT_STATUS" == "clean" ]]; then
    STATUS_COLOR=$GREEN
    STATUS_SYMBOL="✓"
else
    STATUS_COLOR=$RED
    STATUS_SYMBOL="✘"
fi

print_kv "Branch" "${LAVENDER}${GIT_CURRENT_BRANCH}${RESET}"
print_kv "Commit" "${YELLOW}${GIT_SHORT_COMMIT}${RESET}"
print_kv "Commit Message" "${LIME}${GIT_COMMIT_MSG}${RESET}"
print_kv "Total Commits" "$GIT_COMMIT_COUNT"
print_kv "Status" "${STATUS_COLOR}${STATUS_SYMBOL} ${GIT_STATUS}${RESET}"
print_kv "Last Commit" "$GIT_LAST_COMMIT_TS"
if [[ "$FOLDER_OR_FILE" == "folder" ]]; then
    print_kv "Latest Tag" "$GIT_LATEST_TAG"
fi
print_kv "Remote" "${BLUE}${GIT_REMOTE_URL}${RESET}"
